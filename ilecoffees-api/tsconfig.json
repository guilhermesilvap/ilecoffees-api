{
"compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],

    "paths":{
        "@/*": ["./src/*"]
    },

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",

    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "react"]
}

}