# Cole no servidor em: /home/deploy/app/ilecoffees-api/.env
# Troque TODOS os valores marcados com <>

DATABASE_URL=postgresql://ilecoffees:<SENHA_DO_BANCO>@localhost:5432/ilecoffees_db

JWT_SECRET=<GERE_COM: openssl rand -hex 32>

PORT=3333

FRONTEND_URL=http://<IP_DO_SERVIDOR>

# Melhor Envio (token de produção)
MELHOR_ENVIO_TOKEN=<TOKEN_DO_MELHOR_ENVIO>
MELHOR_ENVIO_SANDBOX=false

# Cloudinary (já configurado)
CLOUDINARY_CLOUD_NAME=duuptrsx8
CLOUDINARY_API_KEY=955146549875426
CLOUDINARY_API_SECRET=<CLOUDINARY_API_SECRET>

# Mercado Pago (deixa vazio por enquanto se não tiver)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Email (opcional — deixa vazio para não enviar emails)
RESEND_API_KEY=
MAIL_FROM=
